{
  "name": "aimparency",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/wrapped-agents/*"
  ],
  "scripts": {
    "dev:backend:delay": "npm run dev:delay -w backend",
    "dev:backend": "dotenv -e .env -- npm run dev -w backend",
    "dev:frontend": "dotenv -e .env -- npm run dev -w frontend",
    "dev:embedder": "bash packages/embedder/start.sh",
    "dev:broker": "dotenv -e .env -- npm run dev -w wrapped-agents-broker",
    "dev:broker-client": "dotenv -e .env -- sh -c 'npm run dev -w wrapped-agents-client -- --port ${PORT_BROKER_CLIENT:-5005}'",
    "dev:gemini-session": "dotenv -e .env -- npm run watch -w wrapped-agents-gemini-session",
    "dev:claude-session": "dotenv -e .env -- npm run watch -w wrapped-agents-claude-session",
    "dev:voice": "dotenv -e .env -- npm run dev -w voice-bridge",
    "dev:mobile:config": "tsx packages/mobile/scripts/generate-config.ts",
    "dev": "npm run dev:mobile:config && dotenv -e .env -- concurrently -n \"BACK,FRNT,GEMI,CLAU,BROK,CLNT,EMBD,MCP,VOICE\" -c \"blue,green,magenta,cyan,yellow,white,red,gray,dim\" \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:gemini-session\" \"npm run dev:claude-session\" \"npm run dev:broker\" \"npm run dev:broker-client\" \"npm run dev:embedder\" \"npm run dev:mcp\" \"npm run dev:voice\"",
    "dev:delay": "npm run dev:backend:delay & npm run dev:frontend",
    "stop-sessions": "npm run stop-sessions -w wrapped-agents-broker",
    "list-sessions": "npm run list-sessions -w wrapped-agents-broker",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test:all",
    "test:all": "npm run test:unit && npm run test:e2e",
    "test:unit": "npm run test:unit:backend && npm run test:unit:frontend && npm run test:unit:shared && npm run test:unit:mcp",
    "test:unit:backend": "npm run test -w backend",
    "test:unit:frontend": "npm run test:unit -w frontend",
    "test:unit:shared": "npm run test -w shared",
    "test:unit:mcp": "npm run test -w mcp",
    "test:e2e": "npm run test:e2e -w frontend",
    "test:e2e:ci": "npm run test:e2e:ci -w frontend",
    "test:watch": "npm run test:unit:frontend",
    "ncu-upgrade": "npx npm-check-updates -u --deep && npm install",
    "dev:mcp": "dotenv -e .env -- npm run dev -w mcp",
    "expose:mcp": "dotenv -e .env -- npm run expose -w mcp",
    "rec-install": "npm install && cd packages/shared && npm install && cd ../backend && npm install && cd ../frontend && npm install && cd ../mcp && npm install"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "main": "index.js",
  "dependencies": {
    "backend": "^1.0.0",
    "csstype": "^3.2.3",
    "entities": "^7.0.0",
    "estree-walker": "^3.0.3",
    "frontend": "^1.0.3",
    "magic-string": "^0.30.21",
    "nanoid": "^5.1.6",
    "picocolors": "^1.1.1",
    "postcss": "^8.5.6",
    "remove-accents": "^0.5.0",
    "shared": "^1.0.0",
    "source-map-js": "^1.2.1",
    "typescript": "^5.9.3",
    "undici-types": "^7.16.0",
    "vue": "^3.5.25",
    "vue-demi": "^0.14.10",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aimparency/v7.git"
  },
  "bugs": {
    "url": "https://github.com/aimparency/v7/issues"
  },
  "homepage": "https://github.com/aimparency/v7#readme"
}
