{
  "name": "mcp",
  "version": "1.0.0",
  "private": true,
  "description": "MCP server for Aimparency - allows LLMs to interact with aims and phases",
  "type": "module",
  "bin": {
    "aimparency-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "rm -rf build && tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "watch": "tsc -w",
    "dev": "tsx --tsconfig tsconfig.dev.json watch src/index.ts",
    "expose": "tsx --tsconfig tsconfig.dev.json scripts/expose.ts",
    "test": "NODE_ENV=test tsx --tsconfig tsconfig.dev.json --test src/**/*.test.ts"
  },
  "files": [
    "build"
  ],
  "keywords": [
    "mcp",
    "aimparency",
    "goals",
    "aims"
  ],
  "author": "Aimparency contributors",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aimparency/v7.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/aimparency/v7/issues"
  },
  "homepage": "https://github.com/aimparency/v7/tree/main/packages/mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.24.3",
    "@trpc/client": "^11.5.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "shared": "*",
    "uuid": "^13.0.0",
    "ws": "^8.18.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.1",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
