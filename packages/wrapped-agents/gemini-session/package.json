{
  "name": "wrapped-agents-gemini-session",
  "version": "1.0.0",
  "private": true,
  "description": "Gemini CLI wrapper with watchdog supervision and bundled web UI.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:webui": "cd webui && npm run build",
    "watch": "tsc -w",
    "start:server": "node dist/index.js",
    "start": "npm run build && npm run build:webui && npm run start:server",
    "dev": "npm run build && concurrently \"npm run start:server\" \"cd webui && npm run dev -- --force\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "aimparency",
    "gemini",
    "watchdog"
  ],
  "author": "Aimparency contributors",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aimparency/v7.git",
    "directory": "packages/wrapped-agents/gemini-session"
  },
  "bugs": {
    "url": "https://github.com/aimparency/v7/issues"
  },
  "homepage": "https://github.com/aimparency/v7/tree/main/packages/wrapped-agents/gemini-session",
  "dependencies": {
    "@types/node": "^25.0.1",
    "@xterm/headless": "^5.5.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "node-pty": "^1.0.0",
    "open": "^11.0.0",
    "socket.io": "^4.8.1",
    "strip-ansi": "^7.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/socket.io": "^3.0.2"
  }
}
