# Real-world effector layer (aim 6119682f) — OPT-IN, disabled by default.
# Gives the wrapped worker session "hands" via Composio's Tool Router MCP server
# (GitHub first: create/manage PRs, issues, etc.). Copy to .env (gitignored) and
# fill in. These must be present in the environment that launches the broker /
# sessions (the broker spawns sessions with the parent process env).

# Master switch. The effector MCP server is attached to the worker ONLY when this
# is exactly "true" AND both values below are set. Leave unset/false to keep the
# current behavior (no real-world tools).
ENABLE_EFFECTORS=false

# Composio API key — from https://app.composio.dev (Settings → API Keys).
COMPOSIO_API_KEY=

# Composio Tool Router MCP endpoint (HTTP) for your GitHub connection. Create a
# GitHub connection in the Composio dashboard (handles GitHub OAuth — no raw
# GitHub token needed here), then copy its Tool Router / MCP server URL.
# The worker attaches it via:  claude --mcp-config <generated file>
# (equivalent to: claude mcp add --transport http github-composio "<URL>" \
#   --headers "X-API-Key:<COMPOSIO_API_KEY>")
COMPOSIO_GITHUB_MCP_URL=

# NOTE: real-world actions (e.g. opening a PR) are outward-facing and
# irreversible-ish. Route them through the human approval/veto checkpoint
# (aim 366ede22) before enabling unattended PR creation.
