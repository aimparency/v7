{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "description": "Aimparency backend service for project state, search, and local browser clients.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.dev.json src/server.ts",
    "dev:delay": "DEV_DELAY=true tsx watch --tsconfig tsconfig.dev.json src/server.ts",
    "build": "rm -rf dist && tsc",
    "start": "node dist/server.js",
    "test": "NODE_ENV=test node scripts/run-tests.mjs"
  },
  "keywords": [
    "aimparency",
    "backend",
    "bowman"
  ],
  "author": "Aimparency contributors",
  "license": "ISC",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aimparency/v7.git",
    "directory": "packages/backend"
  },
  "bugs": {
    "url": "https://github.com/aimparency/v7/issues"
  },
  "homepage": "https://github.com/aimparency/v7/tree/main/packages/backend#readme",
  "dependencies": {
    "@trpc/server": "^11.7.2",
    "better-sqlite3": "^12.5.0",
    "express": "^5.2.1",
    "flexsearch": "^0.8.212",
    "fs-extra": "^11.3.2",
    "fuse.js": "^7.1.0",
    "shared": "*",
    "uuid": "^13.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.0.1",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
